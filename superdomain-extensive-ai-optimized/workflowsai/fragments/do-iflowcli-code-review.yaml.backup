# =============================================================================
# iflowcli 深度代码审计模块 - 使用 iFlow CLI 进行安全代码审计
# =============================================================================
# 功能：
# - 使用 iflowcli 进行代码审计
# - 分析源码安全问题
# - 生成详细的安全报告
# =============================================================================

kind: module
name: iflowcli-deep-code-review
description: iflowcli-powered deep security code review

params:
  - name: repoFolder
    default: "{{Output}}/repo"
  - name: iflowcliReportOutput
    default: "{{Output}}/ai-analysis/iflowcli-code-review-{{TargetSpace}}.md"
  - name: enableIflowcliCodeReview
    type: bool
    default: true
    description: "Enable iflowcli deep code review"
  - name: iflowcliModel
    type: string
    default: ""
    description: "iflowcli model to use (optional)"

steps:
  - name: check-repo-exists
    type: function
    pre_condition: "{{enableIflowcliCodeReview}}"
    functions:
      - 'log_info("Starting iflowcli code review for {{Target}}")'

  - name: iflowcli-code-review
    type: agent-acp
    pre_condition: "{{enableIflowcliCodeReview}} && dir_length('{{repoFolder}}') > 0"
    agent: iflow
    cwd: "{{repoFolder}}"
    allowed_paths:
      - "{{repoFolder}}"
      - "{{Output}}"
    acp_config:
      write_enabled: false
    messages:
      - role: system
        content: |
          You are a senior security engineer conducting a comprehensive security code review.
          Analyze the codebase for security vulnerabilities and provide detailed findings.
      - role: user
        content: |
          Perform a comprehensive security code review of this repository for {{Target}}.
          
          Focus on finding:
          - SQL Injection vulnerabilities
          - Command Injection
          - Authentication/Authorization bypass
          - Hardcoded secrets and credentials
          - Cross-Site Scripting (XSS)
          - Path Traversal
          - Deserialization issues
          - Insecure deserialization
          - XXE vulnerabilities
          - SSRF vulnerabilities
          - IDOR vulnerabilities
          - Business logic vulnerabilities
          
          For each finding provide:
          - File path and line number
          - Vulnerability type
          - Severity (Critical/High/Medium/Low)
          - Description
          - Proof of concept
          - Remediation建议
          
          Generate a detailed markdown report sorted by severity.
    exports:
      iflowcli_review: "{{acp_output}}"

  - name: save-iflowcli-report
    type: bash
    pre_condition: "{{enableIflowcliCodeReview}} && defined('iflowcli_review')"
    command: |
      mkdir -p {{Output}}/ai-analysis 2>/dev/null || true
      
      cat > {{iflowcliReportOutput}} << 'EOF'
      # iflowcli Code Review Report
      ## Target: {{Target}}
      ## Repository: {{repoFolder}}
      ## Generated: $(date '+%Y-%m-%d %H:%M:%S')

      ---

      {{iflowcli_review}}

      ---

      *This report was generated by iflowcli AI Code Review*
      EOF
      
      echo "[iflowcli Code Review] Report saved to {{iflowcliReportOutput}}"

  - name: iflowcli-review-fallback
    type: agent-acp
    pre_condition: "{{enableIflowcliCodeReview}} && dir_length('{{repoFolder}}') == 0"
    agent: claude-code
    cwd: "{{Output}}"
    allowed_paths:
      - "{{Output}}"
    messages:
      - role: system
        content: |
          You are a security code review assistant.
      - role: user
        content: |
          No repository found at {{repoFolder}} for code review.
          This is expected if no source code was discovered during the scan.
    exports:
      iflowcli_fallback_msg: "{{acp_output}}"

  - name: log-iflowcli-complete
    type: function
    pre_condition: "{{enableIflowcliCodeReview}}"
    functions:
      - 'log_info("iflowcli code review completed for {{Target}}")'
